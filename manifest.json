{
  "manifest_version": 3,
  "name": "Beacon",
  "version": "1.0.0",
  "description": "Beacon — documents in Drive, autofill for immigration and other web forms (Yutori + Landing AI)",
  "permissions": [
    "identity",
    "storage",
    "sidePanel",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://www.googleapis.com/*",
    "https://www.google.com/*",
    "http://127.0.0.1/*",
    "http://localhost/*",
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "oauth2": {
    "client_id": "54213658700-06joqhgbggtv93ok7444b0teha8kvric.apps.googleusercontent.com",
    "scopes": [
      "openid",
      "https://www.googleapis.com/auth/userinfo.email",
      "https://www.googleapis.com/auth/drive.file",
      "https://www.googleapis.com/auth/drive.readonly",
      "https://www.googleapis.com/auth/drive.metadata.readonly"
    ]
  },
  "action": {},
  "side_panel": {
    "default_path": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}
